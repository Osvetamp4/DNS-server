    #given a request header we construct the correst response object and return it
    def determine_response(self, request, incoming_ip):
        #If request is for domain we are authoritative over, return the correct response
        #If request is for a domain we are not authoritative over, then determine if client is local, if is then forward request to root server, else reject
        qname = request.q.qname
        qtype = request.q.qtype
        is_authoritative = str(qname).endswith(self.domain) or str(qname).endswith("." + self.domain)
        is_local = (incoming_ip == "127.0.0.1")
        response = request.reply()
        
        if is_authoritative:
            #do this only if this dns server is authoritative for the req domain
            response.header.aa = 1
            
            relevant_NS_records = [record for record in self.records[RecordType.NS.value] if record.rname == qname]
            relevant_A_records = [record for record in self.records[RecordType.A.value] if record.rname == qname]

            if qtype == RecordType.NS.value:
                for NS_record in relevant_NS_records:
                    response.add_answer(NS_record)
                for A_record in relevant_A_records:
                    response.add_ar(A_record)
            elif qtype == RecordType.A.value:
                if len(relevant_NS_records) > 0:
                    for NS_record in relevant_NS_records:
                        response.add_auth(NS_record)
                    for A_record in relevant_A_records:
                        response.add_ar(A_record)
                else:
                    if len(relevant_A_records) > 0:
                        for A_record in relevant_A_records:
                            response.add_answer(A_record)
                    else:
                        response.header.rcode = 3 #NXDOMAIN No A records exist for the domain, but we are authoritative so we return NXDOMAIN
        elif is_local:
            #forward the request to the root server and return the response
            pass
        else:
            response.header.rcode = 5 #REFUSED
            pass
        return response

