    #returns a mini dictionary of records
    def find_records(self,domain_name):
        found_records = []
        for record in self.recordList:
            if record.rname == domain_name:
                found_records.append(record)
        return found_records
    
    #Recursively goes through zone file CNAME records to find the correct A record if one exists, otherwise returns the CNAME record
    #Returns record object
    #no defense against zone file CNAMe loops
    #
    def recursive_cname_query(self,response, current_CNAME_record,glue=False):
        if current_CNAME_record.rtype == RecordType.CNAME.value:
            if glue == False:
                response.add_answer(current_CNAME_record)
            next_record = self.find_records(current_CNAME_record.rdata.label)
            if len(next_record) == 1 and next_record[0].rtype == RecordType.CNAME.value:
                return self.recursive_cname_query(response, next_record[0],glue)
        return response

    #given a request header we construct the correst response object and return it
    def determine_response(self, request, incoming_ip):
        #If request is for domain we are authoritative over, return the correct response
        #If request is for a domain we are not authoritative over, then determine if client is local, if is then forward request to root server, else reject
        qname = request.q.qname
        qtype = request.q.qtype
        is_authoritative = str(qname).endswith(self.domain) or str(qname).endswith("." + self.domain)
        is_local = (incoming_ip == "127.0.0.1")
        response = request.reply()
        
        if is_authoritative:
            #do this only if this dns server is authoritative for the req domain
            response.header.aa = 1
            
            relevant_NS_records = [record for record in self.records[RecordType.NS.value] if record.rname == qname]
            relevant_A_records = [record for record in self.records[RecordType.A.value] if record.rname == qname]
            relevant_CNAME_records = [record for record in self.records[RecordType.CNAME.value] if record.rname == qname]

            if qtype == RecordType.NS.value:
                for NS_record in relevant_NS_records:
                    response.add_answer(NS_record)
                for A_record in relevant_A_records:
                    response.add_ar(A_record)
                #add CNAME resolving search
            elif qtype == RecordType.A.value:
                if len(relevant_NS_records) > 0: #If there are relevant NS records for this A record query
                    for NS_record in relevant_NS_records:
                        response.add_auth(NS_record)
                    for A_record in relevant_A_records:
                        response.add_ar(A_record)
                    #Add CNAMe record search but with glue
                else: #If there are no relevant NS records for this A record query
                    if len(relevant_A_records) > 0: #If there are relevant A records for this A record query
                        for A_record in relevant_A_records:
                            response.add_answer(A_record)
                        #add own NS records, NOT relevant NS records, it is optional but prolly do it later
                    #Also search for CNAMe record search
                    else:#We have found no relevant NS record or A records for this A record query
                        response.header.rcode = 3 #NXDOMAIN No A records exist for the domain, but we are authoritative so we return NXDOMAIN
        elif is_local:
            #forward the request to the root server and return the response
            pass
        else:
            response.header.rcode = 5 #REFUSED
            pass
        return response

    def run(self):
        seq = 0

        while True:
            socks = select.select([self.socket], [], [], 0.1)[0]
            for conn in socks:
                self.recv(conn)

        return

